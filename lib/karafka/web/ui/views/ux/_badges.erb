<div>
  <span class="badge">.badge</span>
  <span class="badge badge-primary">.badge .badge-primary</span>
  <span class="badge badge-info">.badge .badge-info</span>
  <span class="badge badge-secondary">.badge .badge-secondary</span>
  <span class="badge badge-success">.badge .badge-success</span>
  <span class="badge badge-warning">.badge .badge-warning</span>
  <span class="badge badge-error">.badge .badge-error</span>
</div>
<div class="mb-6"></div>

<div>
  <%== badge '#badge' %>
  <%== badge_primary '#badge_primary' %>
  <%== badge_info '#badge_info' %>
  <%== badge_secondary '#badge_secondary' %>
  <%== badge_success '#badge_success' %>
  <%== badge_warning '#badge_warning' %>
  <%== badge_error '#badge_error' %>
</div>
<div class="mb-6"></div>

<div>
  <% %w[running quiet stopped].each do |status| %>
    <span class="badge <%= status_badge(status) %>">status_badge('<%= status %>')</span>
  <% end %>
</div>
<div class="mb-6"></div>

<div>
  <% { -1 => 'negative', 0 => 'zero', 1 => 'positive' }.each do |trend, label| %>
    <span class="badge <%= lag_trend_badge(trend) %>">lag_trend_badge(<%= label %>)</span>
  <% end %>
</div>
<div class="mb-6"></div>

<div>
  <% %w[active down].each do |state| %>
    <span class="badge <%= kafka_state_badge(state) %>">kafka_state_badge('<%= state %>')</span>
  <% end %>
</div>
<div class="mb-6"></div>

<div>
  <% [:active, :at_risk, :stopped].each do |risk_state| %>
    <%
      details = Struct.new(:lso_risk_state).new(risk_state)
      classes = lso_risk_state_badge(details)
    %>
    <span class="badge <%= classes %>">lso_risk_state_badge(<%= risk_state %>)</span>
  <% end %>
</div>
<div class="mb-6"></div>
