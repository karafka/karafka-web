#!/usr/bin/env ruby
# frozen_string_literal: true

# Collects timing data from Minitest runs for both regular and pro tests.
# Results are stored in test/timings/{regular,pro}.json for use by bin/balance_tests.
#
# Usage: bin/collect_timings

require 'json'
require 'open3'
require 'fileutils'

TIMINGS_DIR = File.expand_path('../test/timings', __dir__)

# Returns test files for the given type
#
# @param tests_type [String] 'regular' or 'pro'
# @return [Array<String>] sorted array of test file paths
def test_files(tests_type)
  all_tests = Dir.glob('test/lib/karafka/web/**/*_test.rb').sort

  case tests_type
  when 'pro' then all_tests.select { |f| f.include?('/pro/') }
  when 'regular' then all_tests.reject { |f| f.include?('/pro/') }
  end
end

# Collects timing data by running tests with verbose output
#
# @param tests_type [String] 'regular' or 'pro'
# @return [Hash<String, Float>] file paths to execution times in seconds
def collect_timings(tests_type)
  puts "Collecting #{tests_type} test timings..."

  env = { 'SPECS_TYPE' => tests_type }
  files = test_files(tests_type)

  puts "  Running #{files.size} test files..."

  timings = {}

  files.each do |file|
    start = Process.clock_gettime(Process::CLOCK_MONOTONIC)
    cmd = ['bundle', 'exec', 'ruby', '-Itest', '-Ilib', file]
    _stdout, _stderr, _status = Open3.capture3(env, *cmd)
    elapsed = Process.clock_gettime(Process::CLOCK_MONOTONIC) - start
    timings[file] = elapsed.round(3)
    puts "    #{file}: #{elapsed.round(3)}s"
  end

  timings
end

# Saves timing data to JSON file
#
# @param tests_type [String] 'regular' or 'pro'
# @param timings [Hash<String, Float>] timing data
def save_timings(tests_type, timings)
  FileUtils.mkdir_p(TIMINGS_DIR)
  file_path = File.join(TIMINGS_DIR, "#{tests_type}.json")

  sorted = timings.sort_by { |_, time| -time }.to_h
  File.write(file_path, JSON.pretty_generate(sorted))

  total = timings.values.sum
  puts "  Saved #{file_path}: #{timings.size} files, #{total.round(1)}s total"
end

# Main
puts '=== Collecting Test Timings ==='
puts

%w[regular pro].each do |tests_type|
  timings = collect_timings(tests_type)
  save_timings(tests_type, timings)
  puts
end

puts 'Done!'
