#!/usr/bin/env bash

# Runs all tests sequentially (regular then pro)
# For parallel execution, use bin/tests_parallel

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "Running tests in sequential mode..."

SPECS_TYPE=regular bundle exec rake test

SPECS_TYPE=pro bundle exec rake test

# Run coverage check
"$SCRIPT_DIR/check_coverage"
